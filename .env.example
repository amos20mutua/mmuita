# Optional for preview mode: leave Supabase vars empty.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Required for current map integration (Google Maps Places + Directions + Traffic).
# Must be a valid Google Maps Browser key (typically starts with AIza).
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
